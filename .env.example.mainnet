# Mainnet (production) configuration. Copy to .env and fill in the blanks:
#   cp .env.example.mainnet .env

# 32-char COOP AA address on MAINNET (required, no default — the build fails
# loudly if unset). Fill in once the mainnet AA is deployed.
VITE_AA_ADDRESS=
VITE_TESTNET=false
# Base URL of the coop-og OG image service. In production coop-og is served
# from the same public domain behind nginx (see coop-og/deploy/README.md).
VITE_OG_URL=https://coop.obyte.org
# contribution-log API (optional — the Contributions card on the user page is
# hidden when unset). Its origin is also appended to the CSP connect-src at build time.
VITE_CONTRIBUTION_LOG_URL=
# Discord forum channel URL — "Forum" link on the Contributions card (optional)
VITE_DISCORD_FORUM_URL=
# App title override (optional).
#VITE_APP_TITLE=
