# Testnet configuration (local development). Copy to .env:
#   cp .env.example.testnet .env

# 32-char COOP AA address on testnet (required).
VITE_AA_ADDRESS=SUOLWPFSOJ3VRM3GDYNEOJLFKAELGBR7
VITE_TESTNET=true
# Base URL of the coop-og OG image service (optional; pnpm dev in coop-og runs on port 4001).
VITE_OG_URL=http://localhost:4001
# contribution-log API (optional — the Contributions card on the user page is
# hidden when unset). Its origin is also appended to the CSP connect-src at build time.
VITE_CONTRIBUTION_LOG_URL=http://localhost:3000
# Discord forum channel URL — "Forum" link on the Contributions card (optional)
VITE_DISCORD_FORUM_URL=https://discord.com/channels/907242851501482037/1025032564219584542
# App title override (optional).
#VITE_APP_TITLE=
